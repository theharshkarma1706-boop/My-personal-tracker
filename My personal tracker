<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics Dashboard</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>📈 Website Analytics</h1>
            <p>Track your website visitors in real-time</p>
        </header>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Visits</h3>
                <div class="stat-number" id="totalVisits">0</div>
            </div>
            <div class="stat-card">
                <h3>Today</h3>
                <div class="stat-number" id="todayVisits">0</div>
            </div>
            <div class="stat-card">
                <h3>Unique Visitors</h3>
                <div class="stat-number" id="uniqueVisitors">0</div>
            </div>
            <div class="stat-card">
                <h3>Live Visitors</h3>
                <div class="stat-number" id="liveVisitors">0</div>
            </div>
        </div>

        <div class="charts-section">
            <canvas id="visitsChart" width="400" height="200"></canvas>
        </div>

        <div class="recent-visits">
            <h3>Recent Visitors</h3>
            <div id="visitorsList"></div>
        </div>

        <!-- Tracking Script Generator -->
        <div class="tracker-code">
            <h3>📋 Embed this on your website:</h3>
            <textarea id="trackingCode" readonly rows="6" cols="80">
<!-- Paste this script in your website's <head> section -->
<script src="https://yourdomain.com/tracker.js"></script>
            </textarea>
            <button onclick="copyTrackingCode()">Copy Code</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="dashboard.js"></script>
</body>
</html>
